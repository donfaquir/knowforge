{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Knowforge",
  "version": "0.6.1",
  "identifier": "com.knowforge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:11186",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Knowforge",
        "width": 1440,
        "height": 900,
        "decorations": true,
        "shadow": true,
        "backgroundColor": "#e8e8e8"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost http://localhost:11186 ws://localhost:11186 ws://localhost:11187; img-src 'self' asset: http://asset.localhost https://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/models/bge-small-zh-v1.5"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
